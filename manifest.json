{
    "manifest_version": 3,
    "name": "TimeWizard",
    "version": "1.0",
    "description": "Paste event times, automatically detect and convert timezones or convert between any two timezones manually.",
    "key": "",
    "icons": {
        "16": "images/timeconverter-icon-16.png",
        "32": "images/timeconverter-icon-32.png",
        "48": "images/timeconverter-icon-48.png",
        "128": "images/timeconverter-icon-128.png"
    },
    "action": {
        "default_popup": "HTML/popup.html"
    },
    "permissions": [
        "geolocation",
        "storage",
        "windows"
    ],
    "background": {
        "service_worker": "scripts/background.js",
        "type": "module"
    },
    "host_permissions": [
        "https://timezone-proxy.albamartindarius.workers.dev/*",
        "<all_urls>"
    ],
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "exclude_matches": [
                "https://chromewebstore.google.com/*",
                "https://chrome.google.com/webstore/*"
            ],
            "js": [
                "scripts/timezoneDetectScript.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "commands": {
        "_execute_action": {
            "suggested_key": {
                "default": "Ctrl+B",
                "mac": "Command+B"
            }
        }
    } 
}
